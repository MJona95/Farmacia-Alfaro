<style>
    .turno {
        font-family: "Poppins";
        padding: 90px 100px;
        container-type: inline-size;
        container-name: about;
    }

    .title {
        color: var(--first-color);
        font-weight: 300;
        text-align: center;
        font-size: clamp(20px, 4vw, 30px);
        padding-bottom: 25px;
    }

    .sub_title {
        color: var(--second-color);
        font-size: clamp(24px, 5vw, 40px);
        text-align: center;
        padding: 25px 0;
    }

    .box {
        display: flex;
        align-items: center;
        justify-content: space-evenly;
        flex-wrap: wrap;
        gap: 20px;
    }

    .card {
        padding: 30px 0;
        width: 250px;
        min-height: 350px;
    }

    .title_card {
        color: var(--first-color);
        font-weight: 500;
        text-align: center;
        padding: 15px 0;
    }

    .semana {
        background-color: var(--first-color);
        color: var(--third-color);
        margin: 2px 0;
        border-radius: 10px;
        min-height: 40px;
        transition: all 0.3s ease;
        overflow: hidden;
        cursor: pointer;
    }

    /* El hover expande todo el contenedor .semana */
    .semana:hover {
        min-height: 80px;
    }

    /* El contenido .nombre comienza oculto */
    .nombre {
        opacity: 0;
        max-height: 0;
        padding: 0 10px;
        text-align: center;
        font-size: 14px;
        line-height: 1.4;
        transition: all 0.3s ease;
        overflow: hidden;
    }

    /* Al hacer hover, mostramos todo el contenido .nombre */
    .semana:hover .nombre {
        opacity: 1;
        max-height: 100px;
        padding: 5px 10px 10px;
    }

    .dias {
        text-align: center;
        padding: 10px 0 5px;
        margin: 0;
        font-weight: 500;
    }

    @container about (width < 900px) {
        .card {
            width: 220px;
            min-height: 280px;
        }
    }

    @media (width < 900px) {
        .turno {
            padding: 80px 40px 60px;
        }
    }
</style>